# Keep these essential team files:
# ✓ change.log (project changelog)
# ✓ install_requirements.txt (setup instructions)
# ✓ run_app_and_tests.txt (run instructions)
# ✓ package.json & package-lock.json (dependencies)
# ✓ run-tests.js (test runner)
# ✓ cucumber.js (Cucumber config)
# ✓ All source code: frontend/, spec/, features/
# ✓ Main server files: server.js, database.js, eslint.config.mjs
